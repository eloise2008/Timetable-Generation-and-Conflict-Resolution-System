@model List<Timetabling.Models.Assignment>
@{
    ViewBag.Title = "Timetable";
    var days = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday" };
    var sessionList = ViewBag.Sessions as List<Timetabling.Models.TimetableSession>;
    var currentSession = ViewBag.Session as Timetabling.Models.TimetableSession;
    int printId = 0;
    if (currentSession != null)
    {
        printId = currentSession.SessionId;
    }
    else if (sessionList != null && sessionList.Count > 0)
    {
        printId = sessionList[0].SessionId;
    }

    // Assign unique color to each department
    var colorPalette = new[] {
        "#3b82f6","#10b981","#f59e0b","#ef4444","#8b5cf6",
        "#06b6d4","#f97316","#84cc16","#ec4899","#14b8a6",
        "#6366f1","#d946ef","#0ea5e9","#22c55e","#eab308",
        "#dc2626","#7c3aed","#0891b2","#16a34a","#ca8a04",
        "#be185d","#0369a1","#15803d","#b45309","#7e22ce",
        "#0e7490","#166534","#92400e","#6b21a8","#155e75",
        "#1e3a5f","#713f12","#4a1942","#052e16","#1c1917",
        "#450a0a","#1e1b4b","#042f2e","#0c0a09","#18181b"
    };
    var deptColors = new System.Collections.Generic.Dictionary<string, string>();
    int colorIdx = 0;
    if (Model != null)
    {
        foreach (var item in Model)
        {
            if (!deptColors.ContainsKey(item.Course.DepartmentName))
            {
                deptColors[item.Course.DepartmentName] = colorPalette[colorIdx % colorPalette.Length];
                colorIdx++;
            }
        }
    }

    var groups = Model != null
        ? Model.GroupBy(m => m.TimeSlot.StartTime + "-" + m.TimeSlot.EndTime)
               .OrderBy(g => g.Key).ToList()
        : new System.Collections.Generic.List<System.Linq.IGrouping<string, Timetabling.Models.Assignment>>();
}

<!-- Top bar -->
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h3 class="fw-bold mb-1">University Timetable</h3>
        <p style="color:var(--text-muted);font-size:14px;margin:0;">
            @if (currentSession != null)
            {
                @(currentSession.AcademicYear + " — " + currentSession.Semester + " Semester")
            }
            else
            {
                <text>Generated by CSP Backtracking Solver</text>
            }
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a href="@Url.Action("Generate","Timetable")" class="btn btn-generate btn">
            <i class="bi bi-magic me-2"></i>Generate
        </a>
        <a href="@Url.Action("History","Timetable")" class="btn btn-outline-secondary">
            <i class="bi bi-clock-history me-1"></i>History
        </a>
        @if (printId > 0)
        {
            <a href="@Url.Action("Print","Timetable", new { id = printId })"
               target="_blank" class="btn btn-outline-secondary">
                <i class="bi bi-printer me-1"></i>Print / PDF
            </a>
        }
    </div>
</div>

<!-- Session switcher -->
@if (sessionList != null && sessionList.Count > 0)
{
    <div class="mb-3 d-flex gap-2 align-items-center flex-wrap">
        <span style="font-size:13px;color:var(--text-muted);">Session:</span>
        @foreach (var s in sessionList)
        {
            <a href="@Url.Action("ViewSession","Timetable", new { id = s.SessionId })"
               class="btn btn-sm @(currentSession != null && currentSession.SessionId == s.SessionId ? "btn-primary" : "btn-outline-primary")">
                @s.Semester @s.AcademicYear
            </a>
        }
    </div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
    </div>
}

@if (Model != null && Model.Count > 0)
{
    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-sm-3">
            <div class="stat-card">
                <div class="stat-icon si-blue"><i class="bi bi-book"></i></div>
                <div>
                    <div class="stat-num">@Model.Count</div>
                    <div class="stat-lbl">Courses Scheduled</div>
                </div>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="stat-card">
                <div class="stat-icon si-green"><i class="bi bi-building"></i></div>
                <div>
                    <div class="stat-num">@Model.Select(m => m.Room.RoomId).Distinct().Count()</div>
                    <div class="stat-lbl">Rooms Used</div>
                </div>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="stat-card">
                <div class="stat-icon si-amber"><i class="bi bi-diagram-3"></i></div>
                <div>
                    <div class="stat-num">@deptColors.Count</div>
                    <div class="stat-lbl">Departments</div>
                </div>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="stat-card">
                <div class="stat-icon si-red"><i class="bi bi-graph-down"></i></div>
                <div>
                    <div class="stat-num">@Model.Sum(m => m.SoftPenalty)</div>
                    <div class="stat-lbl">Soft Penalty</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Department color legend -->
    <div class="card mb-3">
        <div class="card-header" style="font-size:13px;">
            <i class="bi bi-palette me-2"></i>Department Legend
        </div>
        <div class="card-body py-2">
            <div class="d-flex flex-wrap gap-2">
                @foreach (var kvp in deptColors)
                {
                    <span style="background:@(kvp.Value)20;
                                 border-left:3px solid @(kvp.Value);
                                 padding:3px 10px;
                                 border-radius:0 4px 4px 0;
                                 font-size:11px;
                                 color:@(kvp.Value);
                                 font-weight:600;">
                        @kvp.Key
                    </span>
                }
                <span style="background:#f59e0b20;border:2px solid #f59e0b;
                             padding:3px 10px;border-radius:4px;
                             font-size:11px;color:#f59e0b;font-weight:600;">
                    ★ UWC — University Wide Course
                </span>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs" id="ttTabs">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#grid">
                <i class="bi bi-grid me-1"></i>Weekly Grid
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#list">
                <i class="bi bi-list-ul me-1"></i>By Department
            </a>
        </li>
    </ul>

    <div class="tab-content" style="border:1px solid var(--border);border-top:none;
         border-radius:0 0 12px 12px;background:#fff;padding:16px;">

        <!-- ══ GRID TAB ══ -->
        <div class="tab-pane fade show active" id="grid">
            <div class="table-responsive">
                <table class="table table-bordered text-center align-middle"
                       style="min-width:860px;font-size:11px;">
                    <thead>
                        <tr style="background:#0f2540;color:#fff;">
                            <th style="width:90px;">Time</th>
                            @foreach (var d in days)
                            {
                                <th>@d</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in groups)
                        {
                            <tr>
                                <td style="background:#f8fafc;font-weight:600;
                                           font-size:10px;white-space:nowrap;">
                                    @g.Key
                                </td>
                                @foreach (var day in days)
                                {
                                    var cells = g.Where(m => m.TimeSlot.Day.Equals(
                                        day, StringComparison.OrdinalIgnoreCase)).ToList();
                                    <td style="vertical-align:top;padding:4px;min-width:120px;">
                                        @if (!cells.Any())
                                        {
                                            <span style="color:#cbd5e1;font-size:11px;">—</span>
                                        }
                                        @foreach (var item in cells)
                                        {
                                            var dc = deptColors.ContainsKey(item.Course.DepartmentName)
                                                ? deptColors[item.Course.DepartmentName] : "#2563a8";

                                            if (item.Course.IsUWC)
                                            {
                                                <!-- UWC course — full border, gold accent -->
                                                <div style="background:@(dc)18;
                                                            border:2px solid @dc;
                                                            border-radius:6px;
                                                            padding:4px 6px;
                                                            margin-bottom:3px;
                                                            text-align:left;">
                                                    <div style="background:@dc;color:#fff;
                                                                font-size:9px;font-weight:700;
                                                                padding:1px 5px;border-radius:3px;
                                                                display:inline-block;margin-bottom:3px;">
                                                        UWC — L@item.Course.CourseLevel
                                                    </div>
                                                    <strong style="display:block;font-size:11px;
                                                                   color:#1e293b;">
                                                        @item.Course.CourseCode
                                                    </strong>
                                                    <span style="display:block;font-size:10px;
                                                                 color:#475569;">
                                                        @item.Course.CourseTitle
                                                    </span>
                                                    <span style="font-size:10px;color:#64748b;">
                                                        <i class="bi bi-building"></i>
                                                        @item.Room.RoomName
                                                        (@item.Room.RoomCapacity seats)
                                                    </span>
                                                </div>
                                            }
                                            else
                                            {
                                                <!-- Regular course — left border in dept color -->
                                                <div style="background:@(dc)12;
                                                            border-left:3px solid @dc;
                                                            border-radius:0 4px 4px 0;
                                                            padding:4px 6px;
                                                            margin-bottom:3px;
                                                            text-align:left;">
                                                    <strong style="display:block;font-size:11px;
                                                                   color:#1e293b;">
                                                        @item.Course.CourseCode
                                                    </strong>
                                                    <span style="display:block;font-size:10px;
                                                                 color:@dc;font-weight:600;">
                                                        @item.Course.DepartmentName
                                                    </span>
                                                    <span style="display:block;font-size:10px;
                                                                 color:#475569;">
                                                        @item.Course.CourseTitle
                                                    </span>
                                                    <span style="font-size:10px;color:#64748b;">
                                                        <i class="bi bi-person"></i>
                                                        @item.Course.LecturerName
                                                        &nbsp;|&nbsp;
                                                        <i class="bi bi-building"></i>
                                                        @item.Room.RoomName
                                                    </span>
                                                </div>
                                            }
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ══ BY DEPARTMENT TAB ══ -->
        <div class="tab-pane fade" id="list">
            @{
                var byDept = Model
                    .GroupBy(m => m.Course.DepartmentName)
                    .OrderBy(g => g.Key).ToList();
            }
            @foreach (var deptGroup in byDept)
            {
                var dc2 = deptColors.ContainsKey(deptGroup.Key)
                    ? deptColors[deptGroup.Key] : "#2563a8";
                <div style="margin-bottom:20px;">
                    <!-- Dept header -->
                    <div style="background:@dc2;color:#fff;padding:8px 14px;
                                border-radius:8px 8px 0 0;font-size:13px;font-weight:600;
                                display:flex;align-items:center;gap:8px;">
                        <i class="bi bi-diagram-3"></i>
                        @deptGroup.Key
                        <span style="background:rgba(255,255,255,.25);padding:1px 8px;
                                     border-radius:10px;font-size:11px;">
                            @deptGroup.Count() courses
                        </span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0"
                               style="font-size:12px;border:1px solid @(dc2)55;border-top:none;">
                            <thead>
                                <tr style="background:@(dc2)15;">
                                    <th>Code</th>
                                    <th>Title</th>
                                    <th>Level</th>
                                    <th>Type</th>
                                    <th>Lecturer</th>
                                    <th>Room</th>
                                    <th>Day</th>
                                    <th>Time</th>
                                    <th>Edit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in deptGroup
                                    .OrderBy(m => m.Course.CourseLevel)
                                    .ThenBy(m => m.TimeSlot.DayOrder)
                                    .ThenBy(m => m.TimeSlot.StartTime))
                                {
                                <tr>
                                    <td>
                                        <strong style="color:@dc2;">
                                            @item.Course.CourseCode
                                        </strong>
                                    </td>
                                    <td>@item.Course.CourseTitle</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            L@item.Course.CourseLevel
                                        </span>
                                    </td>
                                    <td>
                                        @if (item.Course.IsUWC)
                                        {
                                            <span class="badge"
                                                  style="background:@dc2;color:#fff;">
                                                UWC
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark border">
                                                Regular
                                            </span>
                                        }
                                    </td>
                                    <td>@item.Course.LecturerName</td>
                                    <td>@item.Room.RoomName</td>
                                    <td>@item.TimeSlot.Day</td>
                                    <td style="white-space:nowrap;">
                                        @item.TimeSlot.StartTime –
                                        @item.TimeSlot.EndTime
                                    </td>
                                    <td>
                                        <a href="@Url.Action("EditEntry", new { id = item.TimetableId })"
                                           class="btn btn-sm btn-outline-primary me-1"
                                           title="Edit this entry">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @using (Html.BeginForm("DeleteEntry", "Timetable",
                                            new { id = item.TimetableId }, FormMethod.Post))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    title="Remove from timetable"
                                                    onclick="return confirm('Remove @item.Course.CourseCode?');">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

    </div>
}
else
{
    <div class="card text-center py-5 mt-2">
        <div class="card-body">
            <i class="bi bi-calendar-x" style="font-size:52px;color:#cbd5e1;"></i>
            <h5 class="mt-3" style="color:var(--text-muted);">No timetable generated yet</h5>
            <p style="color:var(--text-muted);font-size:14px;">
                Click <strong>Generate</strong> above to run the CSP solver.
            </p>
            <a href="@Url.Action("Generate","Timetable")" class="btn btn-primary mt-2">
                <i class="bi bi-magic me-1"></i>Generate Timetable
            </a>
        </div>
    </div>
}
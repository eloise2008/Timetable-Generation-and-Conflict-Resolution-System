@model List<Timetabling.Models.TimetableSession>
@{ ViewBag.Title = "Timetable History"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">Timetable History</h3>
        <p style="color:var(--text-muted);font-size:14px;margin:0;">
            All previously generated timetable sessions
        </p>
    </div>
    <a href="@Url.Action("Generate")" class="btn btn-generate btn">
        <i class="bi bi-magic me-2"></i>Generate New
    </a>
</div>

@if (!Model.Any())
{
    <div class="card text-center py-5">
        <div class="card-body">
            <i class="bi bi-clock-history" style="font-size:52px;color:#cbd5e1;"></i>
            <h5 class="mt-3" style="color:var(--text-muted);">No timetables generated yet</h5>
            <p style="color:var(--text-muted);font-size:14px;">
                Click <strong>Generate New</strong> to create your first timetable.
            </p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0" style="font-size:13px;">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Session Name</th>
                            <th>Academic Year</th>
                            <th>Semester</th>
                            <th>Courses</th>
                            <th>Generated By</th>
                            <th>Generated At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td>@(i++)</td>
                                <td><strong>@s.SessionName</strong></td>
                                <td>@s.AcademicYear</td>
                                <td>
                                    <span class="badge @(s.Semester == "Alpha" ? "bg-primary" : "bg-success")">
                                        @s.Semester
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        @s.TotalCourses courses
                                    </span>
                                </td>
                                <td>@s.GeneratedBy</td>
                                <td>@s.GeneratedAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    <a href="@Url.Action("ViewSession", new { id = s.SessionId })"
                                       class="btn btn-sm btn-outline-primary me-1"
                                       title="View Timetable">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Print", new { id = s.SessionId })"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-secondary me-1"
                                       title="Print / Download PDF">
                                        <i class="bi bi-printer"></i>
                                    </a>
                                    @using (Html.BeginForm("Delete", "Timetable",
                                        new { id = s.SessionId }, FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Delete this timetable session? This cannot be undone.');">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
@{
    ViewBag.Title = "Assign Courses";
    var lecturer = ViewBag.Lecturer as Timetabling.Models.Lecturer;
    var all = ViewBag.AllCourses as List<Timetabling.Models.Course>;
    var mine = ViewBag.MyCourses as List<Timetabling.Models.Course>;
    var mineIds = new HashSet<int>(mine.Select(c => c.CourseId));
    var unassigned = all.Where(c => !mineIds.Contains(c.CourseId)).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">Assign Courses</h3>
        <p style="color:var(--text-muted);font-size:14px;margin:0;">
            <a href="@Url.Action("Index")">Lecturers</a> ›
            @lecturer.LecturerName
        </p>
    </div>
</div>

<div class="row g-4">
    <!-- Currently assigned -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-check-circle text-success me-2"></i>
                Assigned Courses
                <span class="badge bg-success ms-1">@mine.Count</span>
            </div>
            <div class="card-body p-0" style="max-height:500px;overflow-y:auto;">
                @if (!mine.Any())
                {
                    <p class="text-muted text-center py-4">No courses assigned yet.</p>
                }
                @foreach (var c in mine.OrderBy(x => x.CourseCode))
                {
                    <div class="d-flex align-items-center justify-content-between
                                px-3 py-2 border-bottom">
                        <div>
                            <strong>@c.CourseCode</strong>
                            <span style="font-size:12px;color:var(--text-muted);
                                         display:block;">@c.CourseTitle</span>
                                        <span class="badge bg-light text-dark border"
                                              style="font-size:10px;">L@c.CourseLevel</span>
                                    </div>
                                    @using (Html.BeginForm("UnassignCourse", "Lecturer",
                                        FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="lecturerId" value="@lecturer.LecturerId" />
                                        <input type="hidden" name="courseId" value="@c.CourseId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Unassign @c.CourseCode?');">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    }
                                </div>
                            }
            </div>
        </div>
    </div>

    <!-- Available to assign -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-plus-circle text-primary me-2"></i>
                Available Courses
                <span class="badge bg-primary ms-1">@unassigned.Count</span>
            </div>
            <!-- Search -->
            <div class="px-3 pt-2">
                <input type="text" id="courseSearch" class="form-control form-control-sm"
                       placeholder="Search courses..." />
            </div>
            <div class="card-body p-0 mt-2" style="max-height:460px;overflow-y:auto;">
                @foreach (var c in unassigned.OrderBy(x => x.CourseCode))
                {
                    <div class="d-flex align-items-center justify-content-between
                                px-3 py-2 border-bottom course-row">
                        <div>
                            <strong>@c.CourseCode</strong>
                            <span style="font-size:12px;color:var(--text-muted);
                                         display:block;">@c.CourseTitle</span>
                                        <span class="badge bg-light text-dark border"
                                              style="font-size:10px;">
                                            L@c.CourseLevel · @c.DepartmentName
                                        </span>
                                    </div>
                                    @using (Html.BeginForm("AssignCourse", "Lecturer",
                                        FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="lecturerId" value="@lecturer.LecturerId" />
                                        <input type="hidden" name="courseId" value="@c.CourseId" />
                                        <button type="submit" class="btn btn-sm btn-primary">
                                            <i class="bi bi-plus"></i> Assign
                                        </button>
                                    }
                                </div>
                            }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('courseSearch').addEventListener('input', function () {
            var term = this.value.toLowerCase();
            document.querySelectorAll('.course-row').forEach(function (row) {
                row.style.display = row.textContent.toLowerCase()
                    .includes(term) ? '' : 'none';
            });
        });
    </script>
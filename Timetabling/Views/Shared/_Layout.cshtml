<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - TimetableDB Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --primary: #1a3c5e;
            --primary-light: #2563a8;
            --accent: #f0a500;
            --sidebar-bg: #0f2540;
            --sidebar-w: 240px;
            --topbar-h: 56px;
            --body-bg: #f4f6fb;
            --card-bg: #ffffff;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--body-bg);
            color: var(--text-main);
            margin: 0;
        }

        /* ── Sidebar ── */
        #sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        .sb-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 18px 20px;
            border-bottom: 1px solid rgba(255,255,255,.07);
            text-decoration: none;
        }

        .sb-brand-icon {
            width: 36px;
            height: 36px;
            background: var(--accent);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            color: var(--sidebar-bg);
            flex-shrink: 0;
        }

        .sb-brand-text {
            color: #fff;
            font-size: 14px;
            font-weight: 600;
            line-height: 1.25;
        }

            .sb-brand-text small {
                display: block;
                font-size: 10px;
                font-weight: 400;
                color: rgba(255,255,255,.38);
            }

        .sb-section {
            font-size: 9.5px;
            font-weight: 600;
            letter-spacing: 1.1px;
            text-transform: uppercase;
            color: rgba(255,255,255,.28);
            padding: 16px 20px 5px;
        }

        .sb-nav {
            flex: 1;
            overflow-y: auto;
            padding-bottom: 12px;
        }

            .sb-nav a {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 9px 20px;
                color: rgba(255,255,255,.58);
                text-decoration: none;
                font-size: 13.5px;
                font-weight: 500;
                border-left: 3px solid transparent;
                transition: all .16s;
            }

                .sb-nav a:hover {
                    color: #fff;
                    background: rgba(255,255,255,.05);
                    border-left-color: rgba(255,255,255,.25);
                }

                .sb-nav a.active {
                    color: #fff;
                    background: rgba(240,165,0,.12);
                    border-left-color: var(--accent);
                }

                .sb-nav a i {
                    font-size: 15px;
                    width: 18px;
                    text-align: center;
                    flex-shrink: 0;
                }

        .sb-foot {
            padding: 12px 20px;
            border-top: 1px solid rgba(255,255,255,.07);
            font-size: 11px;
            color: rgba(255,255,255,.22);
        }

        /* ── Topbar ── */
        #topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-w);
            right: 0;
            height: var(--topbar-h);
            background: var(--card-bg);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 24px;
            gap: 14px;
            z-index: 999;
        }

        .topbar-title {
            flex: 1;
            font-size: 15px;
            font-weight: 600;
            color: var(--text-main);
        }

        .topbar-badge {
            background: var(--primary);
            color: #fff;
            font-size: 11.5px;
            font-weight: 600;
            padding: 4px 13px;
            border-radius: 20px;
        }

        /* ── Main ── */
        #main {
            margin-left: var(--sidebar-w);
            margin-top: var(--topbar-h);
            padding: 26px;
            min-height: calc(100vh - var(--topbar-h));
        }

        /* ── Cards ── */
        .card {
            border: 1px solid var(--border);
            border-radius: 12px;
            box-shadow: 0 1px 3px rgba(0,0,0,.04);
        }

        .card-header {
            background: var(--card-bg);
            border-bottom: 1px solid var(--border);
            border-radius: 12px 12px 0 0 !important;
            padding: 14px 18px;
            font-weight: 600;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* ── Stat cards ── */
        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .si-blue {
            background: rgba(37,99,168,.11);
            color: #2563a8;
        }

        .si-amber {
            background: rgba(240,165,0,.12);
            color: #b37a00;
        }

        .si-green {
            background: rgba(22,163,74,.1);
            color: #16a34a;
        }

        .si-red {
            background: rgba(220,38,38,.1);
            color: #dc2626;
        }

        .si-slate {
            background: rgba(100,116,139,.1);
            color: #475569;
        }

        .stat-num {
            font-size: 26px;
            font-weight: 700;
            line-height: 1;
            color: var(--text-main);
        }

        .stat-lbl {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        /* ── Table ── */
        .table {
            font-size: 13.5px;
        }

            .table thead th {
                background: #f8fafc;
                color: var(--text-muted);
                font-size: 10.5px;
                font-weight: 600;
                letter-spacing: .6px;
                text-transform: uppercase;
                border-bottom: 1px solid var(--border);
            }

            .table td {
                vertical-align: middle;
                border-color: var(--border);
            }

            .table tbody tr:hover {
                background: #f8fafc;
            }

        /* ── Buttons ── */
        .btn-primary {
            background: var(--primary-light);
            border-color: var(--primary-light);
            font-weight: 500;
        }

            .btn-primary:hover {
                background: var(--primary);
                border-color: var(--primary);
            }

        .btn-generate {
            background: var(--accent);
            border: none;
            color: var(--sidebar-bg);
            font-weight: 700;
            font-size: 14px;
            padding: 10px 24px;
            border-radius: 8px;
        }

            .btn-generate:hover {
                background: #d4920a;
                color: var(--sidebar-bg);
            }

        /* ── Forms ── */
        .form-label {
            font-size: 13px;
            font-weight: 600;
        }

        .form-control, .form-select {
            border-color: var(--border);
            border-radius: 8px;
            font-size: 13.5px;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--primary-light);
                box-shadow: 0 0 0 3px rgba(37,99,168,.11);
            }

        /* ── Alerts ── */
        .alert {
            border-radius: 10px;
            font-size: 13.5px;
            border: none;
        }

        .alert-success {
            background: rgba(22,163,74,.1);
            color: #16a34a;
        }

        .alert-danger {
            background: rgba(220,38,38,.1);
            color: #dc2626;
        }

        /* ── Timetable grid ── */
        .tt-card {
            background: rgba(37,99,168,.07);
            border-left: 3px solid var(--primary-light);
            border-radius: 0 6px 6px 0;
            padding: 5px 8px;
            margin-bottom: 4px;
            font-size: 11px;
        }

            .tt-card.warn {
                background: rgba(240,165,0,.1);
                border-left-color: #d97706;
            }

            .tt-card strong {
                font-size: 11.5px;
                display: block;
            }

        /* ── Nav tabs ── */
        .nav-tabs .nav-link {
            font-size: 13.5px;
            color: var(--text-muted);
        }

            .nav-tabs .nav-link.active {
                color: var(--primary-light);
                font-weight: 600;
            }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <nav id="sidebar">
        <a class="sb-brand" href="@Url.Action("Index","Home")">
            <div class="sb-brand-icon"><i class="bi bi-calendar3"></i></div>
            <div class="sb-brand-text">TimetableDB <small>University Admin</small></div>
        </a>
        <div class="sb-nav">
            <div class="sb-section">Main</div>
            <a href="@Url.Action("Index","Home")"
               class="@(ViewContext.RouteData.Values["controller"].ToString()=="Home"?"active":"")">
                <i class="bi bi-grid-1x2"></i> Dashboard
            </a>
            @*<a href="@Url.Action("Index","Timetable")"
           class="@(ViewContext.RouteData.Values["controller"].ToString()=="Timetable"?"active":"")">
            <i class="bi bi-calendar-week"></i> Timetable
        </a>*@
            <div class="sb-section">Timetable</div>
            <a href="@Url.Action("Index","Timetable")"
               class="@(ViewContext.RouteData.Values["controller"].ToString()=="Timetable" && ViewContext.RouteData.Values["action"].ToString()=="Index" ? "active" : "")">
                <i class="bi bi-calendar-week"></i> View Timetable
            </a>
            <a href="@Url.Action("Generate","Timetable")"
               class="@(ViewContext.RouteData.Values["action"].ToString()=="Generate" ? "active" : "")">
                <i class="bi bi-magic"></i> Generate
            </a>
            <a href="@Url.Action("Index","Conflict")"
               class="@(ViewContext.RouteData.Values["controller"].ToString()=="Conflict"?"active":"")">
                <i class="bi bi-tools"></i> Conflict Resolution
            </a>
            <a href="@Url.Action("History","Timetable")"
               class="@(ViewContext.RouteData.Values["action"].ToString()=="History" ? "active" : "")">
                <i class="bi bi-clock-history"></i> History
            </a>
            <div class="sb-section">Management</div>
            <a href="@Url.Action("Index","Course")"
               class="@(ViewContext.RouteData.Values["controller"].ToString()=="Course"?"active":"")">
                <i class="bi bi-book"></i> Courses
            </a>
            <a href="@Url.Action("Index","Lecturer")"
               class="@(ViewContext.RouteData.Values["controller"].ToString()=="Lecturer"?"active":"")">
                <i class="bi bi-person-badge"></i> Lecturers
            </a>
            <a href="@Url.Action("Index","Room")"
               class="@(ViewContext.RouteData.Values["controller"].ToString()=="Room"?"active":"")">
                <i class="bi bi-building"></i> Rooms
            </a>
            <a href="@Url.Action("Index","TimeSlot")"
               class="@(ViewContext.RouteData.Values["controller"].ToString()=="TimeSlot"?"active":"")">
                <i class="bi bi-clock"></i> Time Slots
            </a>
            <a href="@Url.Action("Index","Department")"
               class="@(ViewContext.RouteData.Values["controller"].ToString()=="Department"?"active":"")">
                <i class="bi bi-diagram-3"></i> Departments
            </a>
            <a href="@Url.Action("Index","Evaluation")"
               class="@(ViewContext.RouteData.Values["controller"].ToString()=="Evaluation"?"active":"")">
                <i class="bi bi-bar-chart-line"></i> Evaluation
            </a>
        </div>
        <div class="sb-foot">&copy; @DateTime.Now.Year University Timetabling System</div>
    </nav>

    <!-- Topbar -->
    <div id="topbar">
        <div class="topbar-title">@ViewBag.Title</div>
        <div class="d-flex align-items-center gap-3">
            <span style="font-size:13px;color:var(--text-muted);">
                <i class="bi bi-person-circle me-1"></i>@ViewBag.FullName
            </span>
            @using (Html.BeginForm("Logout", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
            }
        </div>
    </div>

    <!-- Main Content -->
    <div id="main">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success d-flex align-items-center mb-4">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center mb-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            </div>
        }

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
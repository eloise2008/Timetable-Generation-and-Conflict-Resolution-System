@model Timetabling.Models.Department
@{ ViewBag.Title = "Add Department"; }

<div class="mb-4">
    <h3 class="fw-bold mb-1">Add Department</h3>
    <p style="color:var(--text-muted);font-size:14px;margin:0;">
        <a href="@Url.Action("Index")">Departments</a> › Add Department
    </p>
</div>

<div class="card" style="max-width:420px;">
    <div class="card-body">
        @using (Html.BeginForm("Create", "Department", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Department Name *</label>
                @Html.TextBoxFor(m => m.DepartmentName,
                    new { @class = "form-control", placeholder = "e.g. Computer Science" })
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-1"></i>Save
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Cancel</a>
            </div>
        }
    </div>
</div>
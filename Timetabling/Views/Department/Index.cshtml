@model List<Timetabling.Models.Department>
@{ ViewBag.Title = "Departments"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">Departments</h3>
        <p style="color:var(--text-muted);font-size:14px;margin:0;">
            @Model.Count department(s) registered
        </p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add Department
    </a>
</div><!-- Search bar -->
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="input-group">
            <span class="input-group-text" style="background:transparent;border-right:none;">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" id="searchInput" class="form-control"
                   placeholder="Search department by departmentname..."
                   style="border-left:none;" />
        </div>
    </div>
</div>

<div class="card" style="max-width:560px;">
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr><th>#</th><th>Department Name</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">
                            No departments yet.
                        </td>
                    </tr>
                }
                @{ int i = 1; }
                @foreach (var d in Model)
                {
                    <tr>
                        <td>@(i++)</td>
                        <td><strong>@d.DepartmentName</strong></td>
                        <td>
                            <a href="@Url.Action("Edit", new { id = d.DepartmentId })"
                               class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            @using (Html.BeginForm("Delete", "Department",
                                new { id = d.DepartmentId }, FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Delete @d.DepartmentName?');">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
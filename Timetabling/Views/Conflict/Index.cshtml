@model Timetabling.Models.UploadViewModel
@{ ViewBag.Title = "Conflict Resolution"; }

<div class="mb-4">
    <h3 class="fw-bold mb-1">Conflict Resolution</h3>
    <p style="color:var(--text-muted);font-size:14px;margin:0;">
        Upload an existing timetable to detect and resolve conflicts
    </p>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-upload text-primary me-2"></i>Upload Timetable
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Upload", "Conflict", FormMethod.Post,
                    new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Academic Year *</label>
                            @Html.TextBoxFor(m => m.AcademicYear,
                                new
                                     {
                                         @class = "form-control",
                                      placeholder = "e.g. 2025/2026"
                                     })
                        </div>
                        <div class="col-12">
                            <label class="form-label">Semester *</label>
                            @Html.DropDownListFor(m => m.Semester,
                                new SelectList(new[] { "Alpha", "Omega" }, Model.Semester),
                                new { @class = "form-select" })
                        </div>
                        <div class="col-12">
                            <label class="form-label">Timetable File *</label>
                            <input type="file" name="timetableFile"
                                   class="form-control" accept=".xlsx,.xls" />
                            <div class="form-text">
                                Upload your existing timetable in Excel format
                                (.xlsx or .xls)
                            </div>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search me-1"></i>
                                Detect Conflicts
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100" style="background:#1a3c5e;color:#fff;border:none;">
            <div class="card-body py-4">
                <h6 class="fw-bold">
                    <i class="bi bi-shield-check me-2"></i>
                    What conflicts are detected?
                </h6>
                <ul style="font-size:13px;opacity:.8;margin:12px 0 0;
                           padding-left:18px;line-height:2.2;">
                    <li>
                        <strong>Lecturer clash</strong> — same lecturer
                        assigned to two rooms at the same time
                    </li>
                    <li>
                        <strong>Room clash</strong> — same room assigned
                        to two courses simultaneously
                    </li>
                    <li>
                        <strong>Capacity violation</strong> — room is too
                        small for the course student population
                    </li>
                </ul>
                <hr style="border-color:rgba(255,255,255,.2);margin:16px 0;" />
                <p style="font-size:12px;opacity:.7;margin:0;">
                    After detection, the CSP solver will automatically
                    reassign only the conflicted courses while keeping
                    all valid assignments intact.
                </p>
            </div>
        </div>
    </div>
</div>
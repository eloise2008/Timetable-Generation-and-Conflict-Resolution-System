@model Timetabling.Models.Room
@{ ViewBag.Title = "Edit Room"; }

<div class="mb-4">
    <h3 class="fw-bold mb-1">Edit Room</h3>
    <p style="color:var(--text-muted);font-size:14px;margin:0;">
        <a href="@Url.Action("Index")">Rooms</a> › Edit Room
    </p>
</div>

<div class="card" style="max-width:560px;">
    <div class="card-body">
        @using (Html.BeginForm("Edit", "Room", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.RoomId)
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Room Name *</label>
                    @Html.TextBoxFor(m => m.RoomName, new { @class = "form-control" })
                </div>
                <div class="col-md-6">
                    <label class="form-label">Capacity *</label>
                    @Html.TextBoxFor(m => m.RoomCapacity,
                        new { @class = "form-control", type = "number", min = "1" })
                </div>
                <div class="col-md-6">
                    <label class="form-label">Room Type</label>
                    @Html.DropDownListFor(m => m.RoomType,
                        new SelectList(new[] {
                            "Lecture Theatre","Classroom","Seminar Room","Lab"
                        }, Model.RoomType), "-- Select Type --", new { @class = "form-select" })
                </div>
                <div class="col-md-6">
                    <label class="form-label">Available Days</label>
                    @Html.TextBoxFor(m => m.RoomAvailability, new { @class = "form-control" })
                    <div class="form-text">Comma-separated or leave blank for all days</div>
                </div>
                <div class="col-12 d-flex gap-2 mt-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Save Changes
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        }
    </div>
</div>
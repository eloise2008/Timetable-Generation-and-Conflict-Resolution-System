@model Timetabling.Models.Course
@{ ViewBag.Title = "Add Course"; }

<div class="mb-4">
    <h3 class="fw-bold mb-1">Add Course</h3>
    <p style="color:var(--text-muted);font-size:14px;margin:0;">
        <a href="@Url.Action("Index")">Courses</a> › Add Course
    </p>
</div>

<div class="card" style="max-width:720px;">
    <div class="card-body">
        @using (Html.BeginForm("Create", "Course", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="row g-3">

                <!-- Course Type — first and most important -->
                <div class="col-12">
                    <label class="form-label">Course Type *</label>
                    <div class="d-flex gap-3">
                        <div class="form-check border rounded px-3 py-2 flex-fill"
                             style="cursor:pointer;" id="typeCard_dept">
                            <input class="form-check-input" type="radio"
                                   name="IsUWCRadio" id="typeDept" value="false"
                                   checked onchange="syncCourseType(this)" />
                            <label class="form-check-label w-100" for="typeDept"
                                   style="cursor:pointer;">
                                <strong>
                                    <i class="bi bi-building me-2 text-primary"></i>
                                    Departmental
                                </strong>
                                <div style="font-size:12px;color:var(--text-muted);">
                                    Only students from one department attend.
                                    Can run simultaneously with other departments.
                                </div>
                            </label>
                        </div>
                        <div class="form-check border rounded px-3 py-2 flex-fill"
                             style="cursor:pointer;" id="typeCard_uwc">
                            <input class="form-check-input" type="radio"
                                   name="IsUWCRadio" id="typeUWC" value="true"
                                   onchange="syncCourseType(this)" />
                            <label class="form-check-label w-100" for="typeUWC"
                                   style="cursor:pointer;">
                                <strong>
                                    <i class="bi bi-people-fill me-2 text-warning"></i>
                                    UWC — University Wide
                                </strong>
                                <div style="font-size:12px;color:var(--text-muted);">
                                    ALL students at this level attend.
                                    No other class at the same level can run at the same time.
                                </div>
                            </label>
                        </div>
                    </div>
                    @Html.HiddenFor(m => m.IsUWC, new { id = "isUWCHidden" })
                </div>

                <div class="col-md-4">
                    <label class="form-label">Course Code *</label>
                    @Html.TextBoxFor(m => m.CourseCode,
                        new { @class = "form-control", placeholder = "e.g. CSC301" })
                </div>
                <div class="col-md-8">
                    <label class="form-label">Course Title *</label>
                    @Html.TextBoxFor(m => m.CourseTitle,
                        new
                             {
                                 @class = "form-control",
                              placeholder = "e.g. Data Structures"
                             })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Level *</label>
                    @Html.DropDownListFor(m => m.CourseLevel,
                        new SelectList(new[] { "100", "200", "300", "400", "500" },
                            Model.CourseLevel),
                        "-- Select Level --", new { @class = "form-select" })
                    <div class="form-text">100 to 500 only</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Semester *</label>
                    @Html.DropDownListFor(m => m.Semester,
                        new SelectList(new[] { "Alpha", "Omega" }, Model.Semester),
                        "-- Select Semester --", new { @class = "form-select" })
                </div>

                <div class="col-md-6" id="deptField">
                    <label class="form-label">Department</label>
                    @Html.DropDownListFor(m => m.DepartmentId,
                        new SelectList(
                            ViewBag.Departments as
                                IEnumerable<Timetabling.Models.Department>,
                            "DepartmentId", "DepartmentName", Model.DepartmentId),
                        "-- Select Department --", new { @class = "form-select" })
                    <div class="form-text">
                        Leave blank for UWC courses
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Lecturer *</label>
                    @Html.DropDownListFor(m => m.LecturerId,
                        new SelectList(
                            ViewBag.Lecturers as
                                IEnumerable<Timetabling.Models.Lecturer>,
                            "LecturerId", "LecturerName", Model.LecturerId),
                        "-- Select Lecturer --", new { @class = "form-select" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Duration</label>
                    @Html.DropDownListFor(m => m.Duration,
                        new SelectList(new[] {
                            new { Val = 1, Text = "1 hour" },
                            new { Val = 2, Text = "2 hours" }
                        }, "Val", "Text", Model.Duration),
                        new { @class = "form-select" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Student Population *</label>
                    @Html.TextBoxFor(m => m.CourseStudentPopulation,
                        new { @class = "form-control", type = "number", min = "1" })
                    <div class="form-text" id="uwcNote" style="display:none;color:#d97706;">
                        For UWC, enter the total number of students
                        at this level across all departments
                    </div>
                </div>

                <div class="col-12 d-flex gap-2 mt-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Save Course
                    </button>
                    <a href="@Url.Action("Index")"
                       class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function syncCourseType(radio) {
            var isUWC = radio.value === 'true';
            document.getElementById('isUWCHidden').value = isUWC;
            document.getElementById('uwcNote').style.display = isUWC ? 'block' : 'none';

            // Highlight selected card
            document.getElementById('typeCard_dept').style.borderColor =
                isUWC ? '#e2e8f0' : '#2563a8';
            document.getElementById('typeCard_dept').style.background =
                isUWC ? '' : 'rgba(37,99,168,.05)';
            document.getElementById('typeCard_uwc').style.borderColor =
                isUWC ? '#f0a500' : '#e2e8f0';
            document.getElementById('typeCard_uwc').style.background =
                isUWC ? 'rgba(240,165,0,.05)' : '';
        }

        // Init on load
        document.addEventListener('DOMContentLoaded', function () {
            var checked = document.querySelector('input[name="IsUWCRadio"]:checked');
            if (checked) syncCourseType(checked);
        });
    </script>
}
@model List<Timetabling.Models.Course>
@{ ViewBag.Title = "Courses"; }

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h3 class="fw-bold mb-1">Courses</h3>
        <p style="color:var(--text-muted);font-size:14px;margin:0;">
            @Model.Count course(s) in database
        </p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add Course
    </a>

</div>
<!-- Search bar -->
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="input-group">
            <span class="input-group-text" style="background:transparent;border-right:none;">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" id="searchInput" class="form-control"
                   placeholder="Search courses by code, title, department or lecturer..."
                   style="border-left:none;" />
        </div>
    </div>
</div>


<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Title</th>
                        <th>Level</th>
                        <th>Department</th>
                        <th>Lecturer</th>
                        <th>Students</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                No courses yet. <a href="@Url.Action("Create")">Add one</a>.
                            </td>
                        </tr>
                    }
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td><strong>@c.CourseCode</strong></td>
                            <td>@c.CourseTitle</td>
                            <td>
                                <span class="badge bg-light text-dark border">
                                    L@c.CourseLevel
                                </span>
                            </td>
                            <td>@c.DepartmentName</td>
                            <td>@c.LecturerName</td>
                            <td>@c.CourseStudentPopulation</td>
                            <td>
                                <a href="@Url.Action("Edit", new { id = c.CourseId })"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @using (Html.BeginForm("Delete", "Course",
                                    new { id = c.CourseId }, FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete @c.CourseCode?');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                            <td><a href="@Url.Action("AssignLecturer", "Course", new { id = c.CourseId })"
   class="btn btn-sm btn-outline-success me-1"
   title="Assign Lecturer">
    <i class="bi bi-person-check"></i>
</a></td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('input', function () {
            var term = this.value.toLowerCase();
            var rows = document.querySelectorAll('tbody tr');
            rows.forEach(function (row) {
                var text = row.textContent.toLowerCase();
                row.style.display = text.includes(term) ? '' : 'none';
            });
        });
    </script>
}
